DATABASE_URL=postgresql://media_ax:media_ax@postgres:5432/media_ax
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2

TMDB_API_KEY=
KOBIS_API_KEY=

# Multi-provider LLM (gemini | groq | ollama)
# Gemini 키 발급: https://aistudio.google.com/app/apikey
# Groq 키 발급:   https://console.groq.com/keys
AI_ENGINE=gemini
GOOGLE_API_KEY=
GROQ_API_KEY=

# Ollama (AI_ENGINE=ollama 시 사용, Docker 필요)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# IMAP (CP 이메일 폴링)
IMAP_HOST=
IMAP_USER=
IMAP_PASS=

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
